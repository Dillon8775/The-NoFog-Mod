{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}+${mc_version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "Dillon8775"
  ],
  "contact": {
    "homepage": "${homepage}",
    "sources": "${sources}",
    "issues": "${issues}"
  },
  "license": "${license}",
  "icon": "${logo}.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "net.dillon.nofogmod.NoFogMod"
    ]
  },
  "mixins": [
    "nofogmod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=26.1-pre.2",
    "java": ">=${java_version}",
    "fabric-api": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "${discord}"
      }
    }
  }
}